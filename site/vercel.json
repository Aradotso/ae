{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mcp.ara.engineer" }],
      "destination": "https://mcp-production-fad4.up.railway.app/:path*"
    },
    { "source": "/install", "destination": "/install.sh" }
  ],
  "headers": [
    {
      "source": "/install(.sh)?",
      "headers": [
        { "key": "content-type", "value": "text/plain; charset=utf-8" },
        { "key": "cache-control", "value": "public, max-age=300, s-maxage=60, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "referrer-policy", "value": "strict-origin-when-cross-origin" },
        { "key": "x-content-type-options", "value": "nosniff" }
      ]
    }
  ]
}
